{
  "expo": {
    "name": "FixIt Noir",
    "slug": "fixit",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "fixit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oqapps.fixit"
    },
    "android": {
      "package": "com.oqapps.fixit"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
